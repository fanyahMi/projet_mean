# Configuration du Projet - Centre Commercial
# Copiez ce fichier en .env et remplissez les valeurs

# MongoDB
MONGO_ROOT_USER=mall_admin
MONGO_ROOT_PASSWORD=CHANGEZ_MOI_mot_de_passe_securise

# JWT (Authentification) - Generez un secret fort: openssl rand -base64 64
JWT_SECRET=CHANGEZ_MOI_secret_jwt_tres_long_et_aleatoire

# CORS
CORS_ORIGIN=http://localhost,https://votre-domaine.com

# Application
APP_BASE_URL=http://localhost
APP_NAME=Centre Commercial

# Swagger API Docs (false par defaut en production)
SWAGGER_ENABLED=false

# SMTP (Emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=votre-email@gmail.com
SMTP_PASS=votre-mot-de-passe-app
SMTP_FROM_EMAIL=votre-email@gmail.com
SMTP_FROM_NAME=Centre Commercial

# Google OAuth
GOOGLE_CLIENT_ID=votre-google-client-id.apps.googleusercontent.com

# Cloudinary (Upload images)
CLOUDINARY_CLOUD_NAME=votre-cloud-name
CLOUDINARY_API_KEY=votre-api-key
CLOUDINARY_API_SECRET=votre-api-secret
